{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "JINHONG (WZJH) Design System tokens — W3C DTCG format. Mirrors tokens/wzjh-tokens.css 1:1. Wenzhou Jinhong Electric Co., Ltd.",
  "$metadata": { "version": "1.0.0", "prefix": "wzjh", "base": "16px = 1rem" },

  "color": {
    "$type": "color",
    "blue": {
      "50":  { "$value": "#EAF6FC", "$description": "subtle brand-tinted band" },
      "100": { "$value": "#CFEAF8", "$description": "light fill / info box" },
      "200": { "$value": "#A6D9F1" },
      "300": { "$value": "#5FC0EA", "$description": "decorative / footer link hover on dark" },
      "400": { "$value": "#35A3D9", "$description": "ACCENT (authentic secondary) — decorative only, fails text contrast" },
      "500": { "$value": "#0BA1E2", "$description": "BRAND — logo/fills/icon strokes. 2.91:1 on white: NOT for text" },
      "600": { "$value": "#0E86C0", "$description": "fill hover / large-text only (4.05:1)" },
      "700": { "$value": "#0A6FB0", "$description": "ACTION — links/buttons/text (5.37:1 AA)" },
      "800": { "$value": "#0A5680", "$description": "action hover / high-contrast text (7.91:1)" },
      "900": { "$value": "#103D5B", "$description": "navy — dark surfaces/footer (11.41:1)" }
    },
    "ink": { "900": { "$value": "#2F2725", "$description": "primary text — warm charcoal (14.61:1)" } },
    "neutral": {
      "white": { "$value": "#FFFFFF" },
      "50":  { "$value": "#F7F7F7" }, "100": { "$value": "#F3F3F4" }, "150": { "$value": "#EEEEEE" },
      "200": { "$value": "#E2E2E2" }, "300": { "$value": "#DDDDDD" }, "400": { "$value": "#C4C4C4" },
      "500": { "$value": "#898989", "$description": "placeholder/disabled (3.5:1) — not body text" },
      "600": { "$value": "#6B6B6B", "$description": "muted text min (5.33:1)" },
      "700": { "$value": "#555555", "$description": "secondary text (7.46:1)" },
      "800": { "$value": "#3A3330" }
    },
    "red":   { "50": { "$value": "#FBEAE9" }, "500": { "$value": "#C8392F" }, "700": { "$value": "#A3201A", "$description": "DANGER/e-stop (7.56:1)" }, "900": { "$value": "#7A1813" } },
    "green": { "50": { "$value": "#E7F4ED" }, "600": { "$value": "#1E874B", "$description": "success fill (white text 4.54:1)" }, "700": { "$value": "#157A41", "$description": "success text (5.40:1)" }, "800": { "$value": "#0F5E32" } },
    "amber": { "50": { "$value": "#FCF3E2" }, "fill": { "$value": "#F5A623", "$description": "warning chip (ink text 7.21:1)" }, "600": { "$value": "#B26A00" }, "700": { "$value": "#8A5200", "$description": "warning text (6.39:1)" } }
  },

  "semantic": {
    "$type": "color",
    "brand":          { "$value": "{color.blue.500}" },
    "accent":         { "$value": "{color.blue.400}" },
    "action":         { "$value": "{color.blue.700}" },
    "action.hover":   { "$value": "{color.blue.800}" },
    "focusRing":      { "$value": "{color.blue.700}" },
    "text":           { "$value": "{color.ink.900}" },
    "text.secondary": { "$value": "{color.neutral.700}" },
    "text.muted":     { "$value": "{color.neutral.600}" },
    "text.onBrand":   { "$value": "{color.neutral.white}" },
    "link":           { "$value": "{color.blue.700}" },
    "surface":        { "$value": "{color.neutral.white}" },
    "surface.subtle": { "$value": "{color.neutral.50}" },
    "surface.inverse":{ "$value": "{color.blue.900}" },
    "border":         { "$value": "{color.neutral.300}" },
    "border.subtle":  { "$value": "{color.neutral.150}" },
    "danger":         { "$value": "{color.red.700}" },
    "success":        { "$value": "{color.green.700}" },
    "warning":        { "$value": "{color.amber.700}" },
    "info":           { "$value": "{color.blue.700}" }
  },

  "fontFamily": {
    "$type": "fontFamily",
    "sans": { "$value": ["zt_rol", "Helvetica Neue", "Helvetica", "Arial", "PingFang SC", "Microsoft YaHei", "Noto Sans SC", "sans-serif"], "$description": "Default. zt_rol is brand-owner-licensed; all fallbacks are system/OFL — no @font-face required." },
    "cjk":  { "$value": ["PingFang SC", "Microsoft YaHei", "Noto Sans SC", "Hiragino Sans GB", "sans-serif"] },
    "mono": { "$value": ["SFMono-Regular", "JetBrains Mono", "Roboto Mono", "Consolas", "Courier New", "monospace"], "$description": "spec values, part numbers, parameters" }
  },
  "fontWeight": { "$type": "fontWeight", "regular": { "$value": 400 }, "medium": { "$value": 500 }, "bold": { "$value": 700 } },
  "fontSize": {
    "$type": "dimension",
    "caption": { "$value": "0.75rem" }, "sm": { "$value": "0.875rem" }, "body": { "$value": "1rem" },
    "lg": { "$value": "1.125rem" }, "h4": { "$value": "1.25rem" }, "h3": { "$value": "1.5rem" },
    "h2": { "$value": "1.875rem" }, "h1": { "$value": "2.25rem" }, "display": { "$value": "3rem" }
  },
  "lineHeight": { "tight": { "$value": "1.15" }, "heading": { "$value": "1.3" }, "body": { "$value": "1.6" }, "cjk": { "$value": "1.75" } },

  "space": {
    "$type": "dimension",
    "1": { "$value": "0.25rem" }, "2": { "$value": "0.5rem" }, "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" }, "5": { "$value": "1.25rem" }, "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" }, "10": { "$value": "2.5rem" }, "12": { "$value": "3rem" },
    "16": { "$value": "4rem" }, "20": { "$value": "5rem" }, "24": { "$value": "6rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "0.125rem" }, "default": { "$value": "0.25rem" }, "lg": { "$value": "0.5rem" },
    "xl": { "$value": "0.75rem" }, "pill": { "$value": "9999px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm":    { "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0", "color": "rgba(47,39,37,0.06)" } },
    "card":  { "$value": { "offsetX": "0", "offsetY": "2px", "blur": "8px", "spread": "0", "color": "rgba(47,39,37,0.08)" } },
    "hover": { "$value": { "offsetX": "0", "offsetY": "6px", "blur": "20px", "spread": "0", "color": "rgba(47,39,37,0.12)" } }
  },
  "motion": {
    "ease":     { "$type": "cubicBezier", "$value": [0.25, 0.8, 0.25, 1] },
    "duration": { "$type": "duration", "fast": { "$value": "120ms" }, "base": { "$value": "200ms" }, "slow": { "$value": "320ms" } }
  },
  "layout": {
    "$type": "dimension",
    "container": { "$value": "80rem" }, "containerNarrow": { "$value": "48rem" }, "touchMin": { "$value": "2.75rem" },
    "breakpoint": { "sm": { "$value": "30rem" }, "md": { "$value": "48rem" }, "lg": { "$value": "64rem" }, "xl": { "$value": "80rem" } }
  },
  "deck": {
    "$description": "Presentation mode — fixed 16:9 canvas. See FOR-PRESENTATIONS.md",
    "canvas": { "width": { "$type": "dimension", "$value": "1280px" }, "height": { "$type": "dimension", "$value": "720px" } },
    "fontSize": { "$type": "dimension", "display": { "$value": "4.5rem" }, "h1": { "$value": "3rem" }, "h2": { "$value": "2.25rem" }, "body": { "$value": "1.5rem" }, "caption": { "$value": "1.125rem" } }
  }
}
